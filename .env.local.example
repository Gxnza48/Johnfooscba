# ============================================================
#  Copiá este archivo a  .env.local  y completá con tus claves
#  (las encontrás en Supabase -> Project Settings -> API)
# ============================================================

# URL del proyecto, ej: https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (es segura para el front, la protege RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Número de WhatsApp por defecto (solo dígitos, con código de país).
# Esto es solo el fallback inicial; el número real se administra desde /admin.
NEXT_PUBLIC_DEFAULT_WHATSAPP=549351009990
